# =========================================================================
# AI Coding Hub 設定例  ->  agent/.env にコピーして自分の値を入れる
# （setup.ps1 を使うと AGENT_TOKEN は自動生成、対話で他も埋まります）
# =========================================================================
# ⚠️ 最重要: ANTHROPIC_API_KEY を絶対に設定しないこと！
#   設定すると Claude Code が Max プランではなく API 課金で動き、
#   想定外の請求が来ます（例: 2 日で $1,800 の事例あり）。
#   Max プランで動かす条件 = 「環境変数にも .env にも ANTHROPIC_API_KEY 無し」。
# =========================================================================

# --- 必須 --------------------------------------------------------------
# エージェント認証トークン（ランダムな秘密。20文字以上推奨）
#   生成例: python -c "import secrets; print(secrets.token_urlsafe(32))"
AGENT_TOKEN=

# Cloudflare Tunnel のトークン（Zero Trust ダッシュボードで発行）
#   旧名 CF_TOKEN も後方互換で読めますが、新規はこちらを使用。
CLOUDFLARE_TUNNEL_TOKEN=

# 公開URL（自分の Cloudflare Tunnel のホスト名）
#   例: https://yourname.example.com  /  https://r.example.workers.dev
#   PASSKEY_RP_ID / CORS はこの値から自動導出されます。
PUBLIC_URL=https://your-tunnel.example.com

# --- 任意 --------------------------------------------------------------
# このPCの識別名
PC_NAME=PC-A

# エージェントの待受ポート
PORT=8766

# IDE トンネル名（VS Code / Cursor をブラウザで開く時の固有名。重複しない値に）
VSCODE_TUNNEL_NAME=aihub-pc
CURSOR_TUNNEL_NAME=aihub-cursor

# Passkey の表示名（ログイン時に出る名前）
PASSKEY_RP_NAME=AI Coding Hub

# 以下は通常 PUBLIC_URL から自動導出されるので空でOK。
# 独自に上書きしたい場合のみ設定する。
#   PASSKEY_RP_ID=your-tunnel.example.com
#   PASSKEY_ORIGINS=https://your-tunnel.example.com,http://127.0.0.1:8765
#   CORS_ORIGINS=https://your-tunnel.example.com
